# Django Security & Core Settings
SECRET_KEY=django-insecure-your-secret-key-goes-here
DEBUG=False
ALLOWED_HOSTS=connect-jeunes.org,www.connect-jeunes.org,localhost,127.0.0.1

# MySQL Database Settings (For VPS connection)
DB_ENGINE=django.db.backends.mysql
DB_NAME=connect_jeunes_db
DB_USER=connect_jeunes_user
DB_PASSWORD=your_secure_password
DB_HOST=mysql_server
DB_PORT=3306

# SMTP Email configurations (Optional, for notifications/newsletters)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=example@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=example@gmail.com

# HTTPS Security Configurations (Set to True once SSL/HTTPS is activated via Certbot)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
